# Elysia API runtime
NODE_ENV=development
PORT=4101
CORS_ORIGIN="http://localhost:4100"
# Public base URL emitted in the OpenAPI spec for Scalar.
OPENAPI_SERVER_URL="http://localhost:4101"
LOG_LEVEL=debug
DATABASE_URL="postgresql://user:password@localhost:5432/boilerplate"

# Optional protection for generated API documentation.
OPENAPI_BASIC_AUTH_USERNAME=
OPENAPI_BASIC_AUTH_PASSWORD=

# Optional private S3/MinIO object storage. These values remain server-only.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_ROOT_PREFIX=uploads

# Add API-only values here as features are introduced.
