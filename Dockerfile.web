# syntax=docker/dockerfile:1.11
FROM oven/bun:1.1.45-alpine AS base
WORKDIR /app
FROM base AS prepare
COPY . .
RUN --mount=type=cache,id=bun-web-prune,target=/root/.bun/install/cache \
    bunx turbo@2.8.1 prune web --docker
FROM base AS deps
COPY --from=prepare /app/out/json/ ./
RUN --mount=type=cache,id=bun-web-install,target=/root/.bun/install/cache \
    bun install --frozen-lockfile --ignore-scripts
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=prepare /app/out/full/ ./
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ARG NEXT_PUBLIC_APP_URL=http://localhost:4100
ARG DATABASE_URL=postgresql://boilerplate:boilerplate@localhost:5432/boilerplate
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV DATABASE_URL=$DATABASE_URL
RUN cd packages/database && ../../node_modules/.bin/prisma generate
RUN --mount=type=cache,id=next-web-build,target=/app/apps/web/.next/cache \
    cd apps/web && NEXT_PRIVATE_SKIP_PATCHING=1 node ../../node_modules/next/dist/bin/next build
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=4100
ENV HOSTNAME=0.0.0.0
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public
USER nextjs
EXPOSE 4100
CMD ["node", "apps/web/server.js"]
