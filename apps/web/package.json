{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.1.45",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../.env.web run next dev --port 4100 --turbopack",
    "build": "NODE_ENV=production NEXT_PRIVATE_SKIP_PATCHING=1 bun --env-file=../../.env.web run next build",
    "start": "bun --env-file=../../.env.web run next start --port 4100",
    "lint": "eslint",
    "check-types": "next typegen && tsc --noEmit",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@mantine/core": "^8.3.0",
    "@mantine/hooks": "^8.3.0",
    "@mantine/notifications": "^8.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/next": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
