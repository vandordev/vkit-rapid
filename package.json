{
	"name": "turbostack",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.1.45",
	"scripts": {
		"build": "bun run check-types && turbo run build",
		"start": "concurrently --names \"api,web\" -c \"blue,green\" \"bun run start:api\" \"bun run start:web\"",
		"start:api": "cd apps/api && bun run start",
		"start:web": "cd apps/web && bun run start",
		"dev": "turbo run dev --filter=web --filter=api",
		"dev:web": "turbo run dev --filter=web",
		"dev:api": "turbo run dev --filter=api",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types",
		"docker:build:web": "turbo run build --filter=web",
		"docker:build:api": "turbo run build --filter=api",
		"clean": "turbo run clean",
		"prepare": "husky"
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"prettier": "^3.7.4",
		"turbo": "^2.8.1",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=22"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"dependencies": {}
}
